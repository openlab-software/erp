{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Serviço responsável por gerenciar conteúdos e componentes de páginas dentro do CMS.\nFaz parte da arquitetura de microserviços utilizada no portfólio de Patrick Ribeiro.",
        "title": "Content Service API",
        "termsOfService": "https://github.com/patrickribeirodev",
        "contact": {
            "name": "Patrick Ribeiro",
            "url": "https://patrickribeiro.dev",
            "email": "contato@patrickribeiro.dev"
        },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/v1",
    "paths": {
        "/pages/{pageID}/components/{componentID}": {
            "patch": {
                "description": "Atualiza parcialmente um componente de uma página",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "components"
                ],
                "summary": "Edita um componente existente",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID da página",
                        "name": "pageID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "ID do componente",
                        "name": "componentID",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Componente atualizado",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Requisição inválida",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}